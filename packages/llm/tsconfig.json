{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": "src",
		"module": "CommonJS",
		"moduleResolution": "node10",
		"types": ["node"],
		"tsBuildInfoFile": "./dist/.tsbuildinfo"
	},
	"include": ["src/**/*"],
	"ts-node": {
		"esm": true,
		"experimentalSpecifierResolution": "node"
	}
}
