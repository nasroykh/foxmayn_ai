{
	"name": "foxmayn-ai",
	"private": true,
	"version": "0.0.0",
	"scripts": {
		"build": "turbo build",
		"dev": "turbo build && concurrently -n api,worker,app -c blue,yellow,green \"pnpm --filter=api dev\" \"pnpm --filter=api dev:worker\" \"pnpm --filter=app dev\"",
		"start": "concurrently -n api,app -c blue,green \"pnpm --filter=api start\" \"pnpm --filter=app start\"",
		"build:db": "pnpm --filter=db build",
		"build:qdrant": "pnpm --filter=qdrant build",
		"build:api": "pnpm --filter=api build",
		"build:app": "pnpm --filter=app build",
		"dev:api": "pnpm --filter=api dev",
		"dev:app": "pnpm --filter=app dev",
		"start:api": "pnpm --filter=api start",
		"start:app": "pnpm --filter=app start",
		"auth:generate": "cd apps/api && pnpm dlx @better-auth/cli generate --config src/config/auth.ts --output ../../packages/db/src/models/auth/schema.ts",
		"db:generate": "pnpm --filter=db db:generate",
		"db:migrate": "pnpm --filter=db db:migrate",
		"db:push": "pnpm --filter=db db:push",
		"skills:symlink:claude": "mkdir -p .claude/skills/ && rm -rf .claude/skills/* && cd .claude/skills/ && ln -s ../../.agents/skills/*/ .",
		"skills:symlink:cursor": "mkdir -p .cursor/skills/ && rm -rf .cursor/skills/* && cd .cursor/skills/ && ln -s ../../.agents/skills/*/ .",
		"skills:symlink:agent": "mkdir -p .agent/skills/ && rm -rf .agent/skills/* && cd .agent/skills/ && ln -s ../../.agents/skills/*/ .",
		"skills:symlink:all": "pnpm skills:symlink:claude && pnpm skills:symlink:cursor && pnpm skills:symlink:agent",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"devDependencies": {
		"concurrently": "^9.2.1",
		"turbo": "^2.3.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@swc/core",
			"argon2",
			"esbuild",
			"msgpackr-extract"
		]
	},
	"engines": {
		"node": ">=18"
	}
}
